<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NEXT CLASS"
            android:textSize="11sp"
            android:textColor="#7DB2FF"
            android:textStyle="bold"
            android:letterSpacing="0.06" />

        <TextView
            android:id="@+id/widget_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#332E6BFF"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:text="OPEN"
            android:textColor="#BBD5FF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_subject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Loading..."
        android:textSize="15sp"
        android:textColor="#ECF2FF"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textSize="12sp"
            android:textColor="#AFC0DE"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" • "
            android:textSize="12sp"
            android:textColor="#AFC0DE" />

        <TextView
            android:id="@+id/widget_room"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Room"
            android:textSize="12sp"
            android:textColor="#AFC0DE" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="#26FFFFFF" />

    <TextView
        android:id="@+id/widget_meal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Meal • --"
        android:textSize="11sp"
        android:textColor="#D5E3FF"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_attendance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Attendance • --"
        android:textSize="11sp"
        android:textColor="#D5E3FF"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_exam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Exam • --"
        android:textSize="11sp"
        android:textColor="#D5E3FF"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
